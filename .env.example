# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
SESSION_SECRET=change-me-to-a-long-random-string

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin
# Comma-separated Google account emails allowed to use admin-only backend endpoints.
ADMIN_EMAILS=admin@example.com

# OpenAI
OPENAI_API_KEY=

# Cron endpoints
ENABLE_CRON=false
CRON_TIME=0 8 * * *
SEND_REPORT_SECRET=

# MongoDB
MONGODB_URI=
MONGODB_DB_NAME=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback
